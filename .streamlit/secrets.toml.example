# Copy this file to .streamlit/secrets.toml and fill in your API key.
# This example file is safe to commit. secrets.toml is gitignored.
#
# For Streamlit Cloud: paste this content into Settings → Secrets.

ANTHROPIC_API_KEY = "sk-ant-..."

# Supabase credentials for per-user progress persistence.
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-supabase-publishable-key"
